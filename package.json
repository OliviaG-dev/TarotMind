{
  "name": "tarotmind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=@tarotmind/client",
    "dev:server": "npm run dev --workspace=@tarotmind/server",
    "build": "npm run build --workspace=@tarotmind/client && npm run build --workspace=@tarotmind/server",
    "lint": "eslint .",
    "preview": "npm run preview --workspace=@tarotmind/client",
    "test": "npm run test --workspace=@tarotmind/client && npm run test --workspace=@tarotmind/server",
    "test:server": "npm run test --workspace=@tarotmind/server",
    "test:e2e": "npm run e2e --workspace=@tarotmind/client",
    "prepare": "node -e \"if(process.env.CI||process.env.VERCEL||process.env.HUSKY==='0'||process.env.NODE_ENV==='production')process.exit(0);require('child_process').execSync('husky',{stdio:'inherit'})\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "client/**/*.{ts,tsx}": "eslint --fix",
    "server/**/*.ts": "eslint --fix",
    "packages/shared/**/*.ts": "eslint --fix"
  }
}
