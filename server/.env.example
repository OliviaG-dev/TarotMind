# Client OAuth « Application Web » — identifiant (pas le secret) utilisé pour vérifier les idToken.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Secret pour signer les JWT de session (génère une chaîne longue aléatoire).
JWT_SECRET=change-moi-en-production-minimum-32-caracteres

PORT=4000

# Optionnel : chemin absolu ou relatif au cwd de l’API (défaut : ./data/tarotmind.db)
# DATABASE_PATH=./data/tarotmind.db
